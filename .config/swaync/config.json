{
    "$schema": "/etc/xdg/swaync/configSchema.json",

    "positionX": "right",
    "positionY": "top",
    "layer": "overlay",
    "control-center-layer": "top",
    "layer-shell": true,
    "cssPriority": "user",
    "ignore-gtk-theme": true,

    "control-center-width": 340,
    "control-center-margin-top": 54,
    "control-center-margin-bottom": 14,
    "control-center-margin-right": 14,
    "control-center-margin-left": 0,

    "notification-window-width": 320,
    "notification-icon-size": 48,
    "notification-body-image-height": 100,
    "notification-body-image-width": 100,

    "timeout": 8,
    "timeout-low": 5,
    "timeout-critical": 0,

    "fit-to-screen": true,
    "keyboard-shortcuts": true,
    "image-visibility": "when-available",
    "transition-time": 150,
    "hide-on-clear": true,
    "hide-on-action": true,
    "script-fail-notify": false,
    "notification-2fa-action": true,
    "notification-inline-replies": false,

    "widgets": [
        "title",
        "dnd",
        "notifications",
        "buttons-grid"
    ],

    "widget-config": {
        "title": {
            "text": "Notifications",
            "clear-all-button": true,
            "button-text": "󰆴 clear"
        },

        "mpris": {
            "image-size": 60,
            "image-radius": 0
        },

        "buttons-grid": {
            "actions": [
                {
                    "label": "󰝟",
                    "command": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
                    "type": "toggle"
                },
                {
                    "label": "󰍭",
                    "command": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
                    "type": "toggle"
                },
                {
                    "label": "󰤨",
                    "command": "kitty --class impala -e impala"
                },
                {
                    "label": "󰂯",
                    "command": "blueman-manager"
                },
                {
                    "label": "󰌾",
                    "command": "hyprlock"
                },
                {
                    "label": "󰐥",
                    "command": "wlogout -b 2"
                }
            ]
        }
    }
}
